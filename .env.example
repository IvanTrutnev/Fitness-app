# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ─── MongoDB (required) ────────────────────────────────────────────────────────
# Local docker:  mongodb://root:password@localhost:27017/link-saver?authSource=admin
# Atlas (cloud): mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/link-saver
MONGO_URL=

# ─── PostgreSQL (optional) ─────────────────────────────────────────────────────
# Only used for a connection health-check; no models or queries depend on it.
# Leave empty to skip PostgreSQL entirely.
# Local docker: postgresql://user:password@localhost:5432/mydb
# Neon (cloud):  postgresql://<user>:<pass>@<host>.neon.tech/neondb?sslmode=require
POSTGRES_URL=

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# ─── Cloudinary (required for avatar / document uploads) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Defaults to http://localhost:5173 and http://127.0.0.1:5173 when not set.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Kafka (optional) ──────────────────────────────────────────────────────────
# Set KAFKA_CONSUME_EVENTS=false to disable Kafka entirely (no broker required).
# The app continues to work without Kafka -- events are silently skipped.
KAFKA_CONSUME_EVENTS=false

# Broker address(es), comma-separated.
# Local docker: localhost:9092
# Upstash:      tops-xxxxx-eu1-kafka.upstash.io:9092
KAFKA_BROKERS=

# SASL credentials — required for Upstash Kafka and other cloud brokers.
# Leave empty when using a local (unauthenticated) broker.
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Consumer group ID (default: fitness-app-group)
KAFKA_GROUP_ID=fitness-app-group
