{
  "name": "fitness-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "kafka:up": "docker-compose -f docker-compose-kafka.yml up -d",
    "kafka:down": "docker-compose -f docker-compose-kafka.yml down",
    "kafka:logs": "docker-compose -f docker-compose-kafka.yml logs -f kafka",
    "kafka:ui": "open http://localhost:8080",
    "kafka:test": "tsx src/scripts/test-kafka.ts",
    "kafka:test:producer": "tsx src/scripts/test-kafka.ts producer",
    "kafka:test:consumer": "tsx src/scripts/test-kafka.ts consumer"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.0.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "sequelize": "^6.35.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-validator": "^3.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/kafkajs": "^1.8.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.15",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
